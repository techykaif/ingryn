{
  "expo": {
    "name": "INGRYN",
    "slug": "ingryn",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "ingryn",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.ingryn.app",
      "infoPlist": {
        "NSCameraUsageDescription": "INGRYN needs camera access to scan ingredient labels.",
        "NSPhotoLibraryUsageDescription": "INGRYN needs photo library access to scan ingredient labels from images."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.ingryn.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.INTERNET"
      ],
      "versionCode": 4
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "INGRYN needs camera access to scan ingredient labels."
        }
      ],
      [
        "expo-image-picker",
        {
          "cameraPermission": "INGRYN needs camera access to scan ingredient labels.",
          "photosPermission": "INGRYN needs photo library access to scan ingredient labels from images."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#F8FAFC"
        }
      ],
      "@react-native-google-signin/google-signin",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "7bc54c18-c6c9-4d68-ae39-04059bb68312"
      },
      "router": {}
    },
    "owner": "techykaif"
  }
}
