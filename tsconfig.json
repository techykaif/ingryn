{
  "extends": "expo/tsconfig.base",   // ✅ Correct

  "compilerOptions": {
    "strict": true,                  // ✅ Recommended

    "paths": {
      "@/*": [
        "./*"
      ]
    }
  },

  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.d.ts",
    "expo-env.d.ts",
    ".expo/types/**/*.ts"
  ]
}